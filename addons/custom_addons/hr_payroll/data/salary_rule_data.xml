<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Basic Salary: computed from contract wage (in TZS) -->
    <record id="rule_basic" model="hr.salary.rule">
        <field name="name">Basic Salary</field>
        <field name="code">BASIC</field>
        <field name="category_id" ref="hr_payroll.category_basic"/>
        <field name="sequence">1</field>
        <field name="condition_select">always</field>
        <field name="amount_select">python</field>
        <field name="amount_python_compute">result = contract.wage</field>
    </record>

    <!-- Overtime rule: computed via overtime_hours * hourly_rate * 1.5 -->
    <record id="rule_overtime" model="hr.salary.rule">
        <field name="name">Overtime 1.5x</field>
        <field name="code">OVERTIME</field>
        <field name="category_id" ref="hr_payroll.category_allowance"/>
        <field name="sequence">5</field>
        <field name="condition_select">always</field>
        <field name="amount_select">python</field>
        <field name="amount_python_compute">result = overtime_hours * contract.hourly_rate * 1.5</field>
    </record>

    <!-- Provident Fund deduction: 12% of basic -->
    <record id="rule_pf" model="hr.salary.rule">
        <field name="name">Provident Fund (12%)</field>
        <field name="code">PF</field>
        <field name="category_id" ref="hr_payroll.category_deduction"/>
        <field name="sequence">10</field>
        <field name="condition_select">always</field>
        <field name="amount_select">percentage</field>
        <field name="amount_percentage">12.0</field>
    </record>

    <!-- Professional Tax: fixed amount (example) -->
    <record id="rule_prof_tax" model="hr.salary.rule">
        <field name="name">Professional Tax</field>
        <field name="code">PTAX</field>
        <field name="category_id" ref="hr_payroll.category_deduction"/>
        <field name="sequence">11</field>
        <field name="condition_select">always</field>
        <field name="amount_select">fixed</field>
        <field name="amount_fixed">50.0</field>
    </record>

    <!-- Net / Total line (sum) -->
    <record id="rule_net" model="hr.salary.rule">
        <field name="name">Net Salary</field>
        <field name="code">NET</field>
        <field name="category_id" ref="hr_payroll.category_total"/>
        <field name="sequence">99</field>
        <field name="condition_select">always</field>
        <field name="amount_select">python</field>
        <field name="amount_python_compute"># computed by payslip aggregation; placeholder\nresult = sum([line.amount for line in payslip.line_ids]) if payslip else 0.0</field>
    </record>

    <!-- Salary structures -->
    <record id="structure_monthly" model="hr.salary.structure">
        <field name="name">Monthly Standard</field>
        <field name="rule_ids" eval="[ref('rule_basic'), ref('rule_overtime'), ref('rule_pf'), ref('rule_prof_tax'), ref('rule_net')]"/>
    </record>

    <record id="structure_weekly" model="hr.salary.structure">
        <field name="name">Weekly Standard</field>
        <field name="rule_ids" eval="[ref('rule_basic'), ref('rule_overtime'), ref('rule_pf'), ref('rule_prof_tax'), ref('rule_net')]"/>
    </record>

</odoo>
