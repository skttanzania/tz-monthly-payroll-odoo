<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Payslip Form View -->
        <record id="view_hr_payslip_form" model="ir.ui.view">
            <field name="name">hr.payslip.form</field>
            <field name="model">hr.payslip</field>
            <field name="arch" type="xml">
                <form string="Payslip">
                    <header>
                        <button name="compute_sheet" string="Compute Sheet" type="object"
                                states="draft" class="btn btn-primary"/>
                        <button name="action_payslip_done" string="Confirm" type="object"
                                states="verify" class="btn btn-primary"/>
                        <button name="action_payslip_draft" string="Set to Draft" type="object"
                                states="cancel" class="btn btn-secondary"/>
                        <button name="action_payslip_cancel" string="Reject" type="object"
                                states="draft,verify" class="btn btn-secondary"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="draft,verify,done,cancel"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="number" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="employee_id"/>
                                <field name="date_from"/>
                                <field name="date_to"/>
                            </group>
                            <group>
                                <field name="contract_id"/>
                                <field name="struct_id"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Salary Computation" name="salary_computation">
                                <field name="line_ids">
                                    <tree string="Salary Lines" editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="name"/>
                                        <field name="code"/>
                                        <field name="category_id"/>
                                        <field name="quantity"/>
                                        <field name="rate"/>
                                        <field name="amount"/>
                                        <field name="total"/>
                                    </tree>
                                </field>
                                <group class="oe_subtotal_footer oe_right">
                                    <field name="basic_wage"/>
                                    <field name="total_amount" class="oe_subtotal_footer_separator"/>
                                    <field name="net_wage" class="oe_subtotal_footer_separator"/>
                                </group>
                            </page>
                            <page string="Attendance" name="attendance">
                                <group>
                                    <field name="employee_id" readonly="1"/>
                                    <field name="date_from" readonly="1"/>
                                    <field name="date_to" readonly="1"/>
                                </group>
                            </page>
                            <page string="Other Info" name="other_info">
                                <group>
                                    <field name="name"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Payslip Tree View -->
        <record id="view_hr_payslip_tree" model="ir.ui.view">
            <field name="name">hr.payslip.tree</field>
            <field name="model">hr.payslip</field>
            <field name="arch" type="xml">
                <tree string="Payslips" decoration-info="state=='draft'"
                      decoration-muted="state=='cancel'">
                    <field name="number"/>
                    <field name="employee_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <field name="struct_id"/>
                    <field name="basic_wage" sum="Basic Wage"/>
                    <field name="net_wage" sum="Net Salary"/>
                    <field name="state"/>
                </tree>
            </field>
        </record>

        <!-- Payslip Search View -->
        <record id="view_hr_payslip_search" model="ir.ui.view">
            <field name="name">hr.payslip.search</field>
            <field name="model">hr.payslip</field>
            <field name="arch" type="xml">
                <search string="Payslips">
                    <field name="name" string="Payslip" filter_domain="['|', ('name','ilike',self), ('number','ilike',self)]"/>
                    <field name="employee_id"/>
                    <field name="date_from"/>
                    <field name="date_to"/>
                    <filter string="Draft" name="draft" domain="[( 'state','=', 'draft' )]"/>
                    <filter string="Done" name="done" domain="[( 'state','=', 'done' )]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter string="Employee" name="employee" context="{'group_by':'employee_id'}"/>
                        <filter string="Status" name="status" context="{'group_by':'state'}"/>
                        <filter string="Structure" name="structure" context="{'group_by':'struct_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Payslip Action -->
        <record id="action_hr_payslip" model="ir.actions.act_window">
            <field name="name">Payslips</field>
            <field name="res_model">hr.payslip</field>
            <field name="view_mode">tree,form</field>
            <field name="search_view_id" ref="view_hr_payslip_search"/>
            <field name="context">{'search_default_current_month': 1}</field>
        </record>

        <!-- Menu Items -->
        <menuitem id="menu_hr_payslip"
                  name="Payslips"
                  parent="menu_hr_payroll_root"
                  action="action_hr_payslip"
                  sequence="5"/>
    </data>
</odoo>
